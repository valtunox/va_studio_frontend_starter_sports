# API Configuration
# In development: leave VITE_API_URL empty — Vite proxies /api/* to localhost:5112
# In production:  set to full backend URL, e.g. https://api.vastudio.com/api/v1
# VITE_API_URL=http://localhost:5112/api/v1
# Environment
VITE_ENV=development
# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_BETA_FEATURES=false
# Debugging
VITE_DEBUG_API=true
VITE_DEBUG_STORAGE=false
# App Metadata
VITE_APP_NAME=VA Studio
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=AI-Powered App Builder
